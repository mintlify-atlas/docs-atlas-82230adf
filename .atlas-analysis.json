  "keyFeatures": [
    "Multi-provider LLM support (OpenAI, Anthropic, DeepSeek, Gemini)",
    "Real-time prompt injection detection",
    "RAG Defense Engine for indirect attacks",
    "Configurable security policies",
    "Comprehensive audit logging",
    "SDK support (Python, JavaScript)",
    "Docker and Kubernetes deployment",
    "Enterprise compliance (SOC 2, GDPR, HIPAA)"
  ],
  "publicApiSurface": [
    "POST /scan - Scan prompt for security threats",
    "POST /scan/rag - Scan RAG context for indirect injection",
    "POST /proxy - Proxy LLM requests with security",
    "GET /health - Service health check",
    "GET /policies - List security policies",
    "KoreshieldClient.scan() - Python SDK scan method",
    "KoreshieldClient.scan_rag_context() - Python SDK RAG scan",
    "Koreshield.scanPrompt() - JavaScript SDK scan method"
